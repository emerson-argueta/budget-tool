<turbo-frame id="modal">
  <div class="fixed inset-0 bg-black/40 flex items-center justify-center z-50"
       data-controller="modal"
       data-action="click->modal#closeOnBackdrop">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-sm p-6" data-modal-target="panel">
      <h2 class="text-lg font-semibold mb-4">Edit Income</h2>
      <%= form_with model: @budget, url: budget_path(@budget), method: :patch do |f| %>
        <div class="mb-4">
          <%= f.label :total_income, "Monthly Take-Home Pay", class: "block text-sm font-medium text-gray-700 mb-1" %>
          <%= f.number_field :total_income, step: "0.01", min: 0,
              class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500",
              autofocus: true %>
        </div>
        <div class="flex justify-end gap-2">
          <%= link_to "Cancel", budget_path(@budget), class: "btn-secondary", data: { turbo_frame: "_top" } %>
          <%= f.submit "Save", class: "btn-primary" %>
        </div>
      <% end %>
    </div>
  </div>
</turbo-frame>
