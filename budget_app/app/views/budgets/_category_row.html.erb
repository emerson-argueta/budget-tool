<div id="budget_category_<%= category.id %>"
     class="px-6 py-3 flex items-center hover:bg-gray-50 group"
     data-controller="budget-category"
     data-budget-category-update-url-value="<%= update_amount_budget_category_path(category) %>">

  <div class="flex-1 flex items-center gap-2">
    <% if category.emoji.present? %>
      <span class="text-lg"><%= category.emoji %></span>
    <% end %>
    <div>
      <span class="text-sm font-medium text-gray-900"><%= category.name %></span>
      <% if category.planned_amount > 0 %>
        <div class="mt-1 w-40 h-1.5 bg-gray-200 rounded-full overflow-hidden">
          <div class="h-full rounded-full <%= category.over_budget? ? 'bg-red-500' : 'bg-indigo-500' %>"
               style="width: <%= category.percent_spent %>%"></div>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Planned (inline editable) — hidden on mobile -->
  <div class="hidden md:block w-28 text-right">
    <span class="text-sm text-gray-700 cursor-pointer hover:text-indigo-600 font-medium"
          data-budget-category-target="planned"
          data-action="click->budget-category#startEdit">
      <%= money(category.planned_amount) %>
    </span>
    <input type="number" step="0.01" min="0"
           class="hidden w-full text-right text-sm border border-indigo-400 rounded px-2 py-0.5 focus:outline-none focus:ring-1 focus:ring-indigo-500"
           data-budget-category-target="input"
           data-action="blur->budget-category#saveEdit keydown.enter->budget-category#saveEdit keydown.escape->budget-category#cancelEdit"
           value="<%= category.planned_amount %>">
  </div>

  <!-- Spent — hidden on mobile -->
  <div class="hidden md:block w-28 text-right">
    <span class="text-sm text-gray-700"><%= money(category.spent) %></span>
  </div>

  <!-- Left -->
  <div class="w-28 text-right">
    <span class="text-sm font-medium <%= category.over_budget? ? 'text-red-600' : 'text-gray-700' %>">
      <%= money(category.remaining) %>
    </span>
  </div>

  <!-- Actions — hidden on mobile -->
  <div class="hidden md:flex w-16 justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
    <%= link_to "✎", edit_budget_category_path(category),
        class: "text-gray-400 hover:text-indigo-600 text-sm",
        data: { turbo_frame: "modal" } %>
    <%= button_to "✕", budget_category_path(category),
        method: :delete,
        class: "text-gray-400 hover:text-red-600 text-sm bg-transparent border-0 cursor-pointer",
        data: { turbo_confirm: "Delete #{category.name}?" } %>
  </div>
</div>
