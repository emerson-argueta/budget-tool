<turbo-frame id="modal">
  <div class="fixed inset-0 bg-black/40 flex items-center justify-center z-50 p-4"
       onclick="if(event.target===this)this.closest('turbo-frame').innerHTML=''">
    <div class="bg-white rounded-xl shadow-xl w-full max-w-3xl max-h-[85vh] flex flex-col">

      <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200 flex-shrink-0">
        <div>
          <h2 class="text-lg font-semibold text-gray-900">Income — <%= @budget.month_label %></h2>
          <% if @transactions.any? %>
            <p class="text-sm text-gray-500 mt-0.5">
              <%= pluralize(@transactions.count, "transaction") %> &middot;
              <%= money(@transactions.sum("ABS(amount)")) %> total
            </p>
          <% end %>
        </div>
        <button onclick="this.closest('turbo-frame').innerHTML=''"
                class="text-gray-400 hover:text-gray-600 text-2xl leading-none p-1">&times;</button>
      </div>

      <div class="overflow-y-auto flex-1">
        <% if @transactions.empty? %>
          <p class="px-6 py-12 text-center text-sm text-gray-400 italic">No income transactions this month.</p>
        <% else %>
          <div class="hidden md:block">
            <table class="w-full text-sm">
              <thead class="sticky top-0 bg-white border-b border-gray-200">
                <tr>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Date</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Merchant</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Account</th>
                  <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wide">Amount</th>
                  <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Action</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                <% @transactions.each do |transaction| %>
                  <%= render "transactions/transaction", transaction: transaction %>
                <% end %>
              </tbody>
            </table>
          </div>

          <div class="md:hidden divide-y divide-gray-100">
            <% @transactions.each do |transaction| %>
              <%= render "transactions/transaction_card", transaction: transaction %>
            <% end %>
          </div>
        <% end %>
      </div>

    </div>
  </div>
</turbo-frame>
