<%= form_with model: [budget, category], data: { turbo_frame: "modal" } do |f| %>
  <div class="space-y-4">
    <div class="flex gap-3">
      <div class="w-16">
        <%= f.label :emoji, "Icon", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :emoji, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-center text-xl focus:outline-none focus:ring-2 focus:ring-indigo-500", maxlength: 2 %>
      </div>
      <div class="flex-1">
        <%= f.label :name, "Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :name, class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500", autofocus: true, placeholder: "e.g. Groceries" %>
      </div>
    </div>

    <div>
      <%= f.label :planned_amount, "Planned Amount", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <div class="relative">
        <span class="absolute left-3 top-2 text-gray-400 text-sm">$</span>
        <%= f.number_field :planned_amount, step: "0.01", min: 0,
            class: "w-full border border-gray-300 rounded-lg pl-7 pr-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500",
            placeholder: "0.00" %>
      </div>
    </div>

    <div>
      <%= f.label :category_group_id, "Group", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.collection_select :category_group_id, @groups || CategoryGroup.ordered, :id, :name,
          { prompt: "Select a group" },
          class: "w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500" %>
    </div>

    <% if category.errors.any? %>
      <div class="text-sm text-red-600">
        <% category.errors.full_messages.each do |msg| %>
          <p><%= msg %></p>
        <% end %>
      </div>
    <% end %>

    <div class="flex justify-end gap-2 pt-2">
      <%= link_to "Cancel", budget_path(budget),
          class: "btn-secondary",
          data: { turbo_frame: "_top" } %>
      <%= f.submit category.persisted? ? "Save Changes" : "Add Category", class: "btn-primary" %>
    </div>
  </div>
<% end %>
