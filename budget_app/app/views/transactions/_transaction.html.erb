<% tx_categories = @budget_categories_by_month&.fetch(transaction.date.beginning_of_month, nil) || @budget_categories %>
<tr id="transaction_<%= transaction.id %>"
    class="hover:bg-gray-50 <%= transaction.pending? ? 'opacity-60' : '' %> <%= transaction.is_income? ? 'bg-green-50' : '' %> <%= transaction.untracked? ? 'bg-gray-50 opacity-60' : '' %>">
  <td class="px-6 py-3 text-gray-500 whitespace-nowrap"><%= transaction.date.strftime("%b %-d") %></td>
  <td class="px-6 py-3">
    <div class="flex items-center gap-2">
      <span class="font-medium text-gray-900"><%= transaction.display_name %></span>
      <% if transaction.manual? %>
        <%= button_to transaction_path(transaction), method: :delete,
            class: "text-gray-300 hover:text-red-500 bg-transparent border-0 p-0 cursor-pointer leading-none",
            data: { turbo_confirm: "Delete this transaction?" },
            title: "Delete" do %>
          &times;
        <% end %>
      <% end %>
    </div>
    <% if transaction.pending? %>
      <span class="text-xs text-gray-400 italic">Pending</span>
    <% end %>
    <% if transaction.is_income? %>
      <span class="text-xs text-green-600 font-medium">Income</span>
    <% end %>
  </td>
  <td class="px-6 py-3 text-gray-500 text-xs"><%= transaction.account.display_name %></td>
  <% display_amount = -transaction.amount %>
  <td class="px-6 py-3 text-right font-medium whitespace-nowrap <%= display_amount.positive? ? 'text-green-600' : 'text-red-600' %>">
    <%= display_amount.positive? ? "+#{money(display_amount)}" : money(display_amount) %>
  </td>
  <td class="px-6 py-3">
    <% if transaction.untracked? %>
      <div class="flex items-center gap-2">
        <span class="text-xs text-gray-400 bg-gray-200 px-2 py-0.5 rounded">↔ Transfer</span>
        <%= form_with model: transaction, url: transaction_path(transaction), method: :patch do |f| %>
          <%= f.hidden_field :untracked, value: "0" %>
          <%= f.submit "Unmark", class: "text-xs text-gray-400 hover:text-gray-600 underline cursor-pointer bg-transparent border-0 p-0" %>
        <% end %>
      </div>
    <% elsif transaction.is_income? %>
      <%= form_with model: transaction, url: transaction_path(transaction), method: :patch do |f| %>
        <%= f.hidden_field :is_income, value: "0" %>
        <%= f.submit "Unmark Income", class: "text-xs text-gray-500 hover:text-gray-700 underline cursor-pointer bg-transparent border-0 p-0" %>
      <% end %>
    <% else %>
      <div class="flex items-center gap-2">
        <%= form_with model: transaction, url: transaction_path(transaction), method: :patch do |f| %>
          <%= f.collection_select :budget_category_id,
              tx_categories,
              :id, :name,
              { include_blank: "— Unassigned —", selected: transaction.budget_category_id },
              class: "w-full border border-gray-300 rounded-md px-2 py-1 text-xs focus:outline-none focus:ring-1 focus:ring-indigo-500",
              onchange: "this.form.requestSubmit()" %>
        <% end %>
        <%= form_with model: transaction, url: transaction_path(transaction), method: :patch do |f| %>
          <%= f.hidden_field :is_income, value: "1" %>
          <%= f.submit "+ Income", class: "text-xs text-green-600 hover:text-green-800 underline cursor-pointer bg-transparent border-0 p-0 whitespace-nowrap" %>
        <% end %>
        <%= form_with model: transaction, url: transaction_path(transaction), method: :patch do |f| %>
          <%= f.hidden_field :untracked, value: "1" %>
          <%= f.submit "↔ Transfer", class: "text-xs text-gray-400 hover:text-gray-600 underline cursor-pointer bg-transparent border-0 p-0 whitespace-nowrap" %>
        <% end %>
      </div>
    <% end %>
  </td>
</tr>
