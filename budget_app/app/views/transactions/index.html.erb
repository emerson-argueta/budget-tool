<%= content_for :title, "Transactions" %>

<div class="flex items-center justify-between mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Transactions</h1>
  <div class="flex items-center gap-2">
    <% if current_user.plaid_items.any? %>
      <%= button_to "Sync", plaid_sync_path, method: :post, class: "btn-secondary text-sm" %>
    <% end %>
    <% unassigned = current_user.transactions.unassigned.count %>
    <% if unassigned > 0 %>
      <%= link_to "#{unassigned} unassigned", unassigned_transactions_path, class: "text-amber-600 font-medium text-sm hover:underline" %>
    <% end %>
    <%= link_to "+ Add Transaction", new_transaction_path, class: "btn-primary text-sm",
        data: { turbo_frame: "modal" } %>
  </div>
</div>

<!-- Filters -->
<div class="bg-white rounded-xl border border-gray-200 p-4 mb-4">
  <%= form_with url: transactions_path, method: :get,
        data: { controller: "auto-submit", turbo_frame: "transactions_results" } do |f| %>
    <div class="flex flex-wrap gap-3 items-end">
      <div>
        <%= f.label :month, "Month", class: "block text-xs font-medium text-gray-500 mb-1" %>
        <%= f.month_field :month, value: @current_filter[:month],
            class: "border border-gray-300 rounded-md px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500",
            data: { action: "change->auto-submit#submitNow" } %>
      </div>
      <div>
        <%= f.label :account_id, "Account", class: "block text-xs font-medium text-gray-500 mb-1" %>
        <%= f.collection_select :account_id, @accounts, :id, :display_name,
            { include_blank: "All accounts" },
            class: "border border-gray-300 rounded-md px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500",
            data: { action: "change->auto-submit#submitNow" } %>
      </div>
      <div>
        <%= f.label :q, "Search", class: "block text-xs font-medium text-gray-500 mb-1" %>
        <%= f.search_field :q, value: @current_filter[:q], placeholder: "Merchant or name…",
            class: "border border-gray-300 rounded-md px-3 py-1.5 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 w-52",
            data: { action: "input->auto-submit#submit" } %>
      </div>
      <div class="flex items-center gap-2 pb-0.5">
        <%= f.check_box :unassigned, { checked: @current_filter[:unassigned] == "1",
            data: { action: "change->auto-submit#submitNow" } }, "1", "0" %>
        <%= f.label :unassigned, "Unassigned only", class: "text-sm text-gray-700" %>
      </div>
      <%= link_to "Clear", transactions_path, class: "text-sm text-gray-500 hover:underline pb-0.5" %>
    </div>
  <% end %>
</div>

<!-- Results (targeted by the form's turbo_frame) -->
<turbo-frame id="transactions_results">
  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <%= render "list", transactions: @transactions %>
  </div>
  <%= render "shared/pagination", pagy: @pagy %>
</turbo-frame>
