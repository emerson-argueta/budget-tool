<%= content_for :title, "Unassigned Transactions" %>

<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Unassigned Transactions</h1>
    <p class="text-sm text-gray-500 mt-1"><%= @pagy.count %> transactions need a category</p>
  </div>
  <%= link_to "All Transactions", transactions_path, class: "btn-secondary" %>
</div>

<div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
  <% if @transactions.empty? %>
    <div class="px-6 py-12 text-center">
      <p class="text-4xl mb-3">✓</p>
      <p class="text-gray-600 font-medium">All transactions are assigned!</p>
    </div>
  <% else %>
    <table class="w-full text-sm">
      <thead>
        <tr class="bg-gray-50 border-b border-gray-200">
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Date</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Merchant</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide">Account</th>
          <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wide">Amount</th>
          <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wide w-64">Assign To</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @transactions.each do |transaction| %>
          <%= render "transaction", transaction: transaction %>
        <% end %>
      </tbody>
    </table>
  <% end %>
</div>

<%= render "shared/pagination", pagy: @pagy %>
