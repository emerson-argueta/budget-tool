<% count = current_user.transactions.unassigned.count %>
<span id="unassigned_count">
  <% if count > 0 %>
    <%= link_to unassigned_transactions_path,
        class: "flex items-center gap-1 text-sm text-amber-700 bg-amber-100 px-3 py-1 rounded-full hover:bg-amber-200" do %>
      <span class="font-semibold"><%= count %></span> unassigned
    <% end %>
  <% end %>
</span>
