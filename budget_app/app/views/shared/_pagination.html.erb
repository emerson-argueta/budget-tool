<% if pagy.last > 1 %>
  <div class="flex items-center justify-between mt-4 text-sm text-gray-500">
    <span>Showing <%= pagy.from %>–<%= pagy.to %> of <%= pagy.count %></span>
    <div class="flex gap-1">
      <% if pagy.previous %>
        <%= link_to "← Prev", url_for(page: pagy.previous), class: "px-3 py-1.5 border border-gray-300 rounded-md hover:bg-gray-50" %>
      <% end %>
      <% if pagy.next %>
        <%= link_to "Next →", url_for(page: pagy.next), class: "px-3 py-1.5 border border-gray-300 rounded-md hover:bg-gray-50" %>
      <% end %>
    </div>
  </div>
<% end %>
