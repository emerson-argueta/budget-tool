<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Budget" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= yield :head %>
    <script src="https://cdn.plaid.com/link/v2/stable/link-initialize.js"></script>
  </head>

  <body class="bg-gray-50 text-gray-900 min-h-screen">
    <% if user_signed_in? %>
      <nav class="bg-white border-b border-gray-200 sticky top-0 z-50" x-data="{ open: false }">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex items-center justify-between h-16">
            <%= link_to "Budget", authenticated_root_path, class: "text-xl font-bold text-indigo-600" %>

            <%# Desktop nav %>
            <div class="hidden md:flex items-center gap-1">
              <%= nav_link "Dashboard", authenticated_root_path %>
              <%= nav_link "Budget", budgets_path %>
              <%= nav_link "Transactions", transactions_path %>
              <%= nav_link "Accounts", accounts_path %>
              <%= nav_link "Sinking Funds", sinking_funds_path %>
              <%= nav_link "Reports", reports_path %>
            </div>

            <%# Desktop right side %>
            <div class="hidden md:flex items-center gap-4">
              <%= render "shared/unassigned_count" %>
              <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-sm text-gray-500 hover:text-gray-700" %>
            </div>

            <%# Mobile hamburger %>
            <button class="md:hidden p-2 rounded-lg text-gray-500 hover:bg-gray-100"
                    onclick="this.closest('nav').querySelector('#mobile-menu').classList.toggle('hidden')">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
              </svg>
            </button>
          </div>
        </div>

        <%# Mobile menu %>
        <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white">
          <div class="px-4 py-2 space-y-0.5">
            <%= nav_link "Dashboard", authenticated_root_path, mobile: true %>
            <%= nav_link "Budget", budgets_path, mobile: true %>
            <%= nav_link "Transactions", transactions_path, mobile: true %>
            <%= nav_link "Accounts", accounts_path, mobile: true %>
            <%= nav_link "Sinking Funds", sinking_funds_path, mobile: true %>
            <%= nav_link "Reports", reports_path, mobile: true %>
          </div>
          <div class="px-4 py-3 border-t border-gray-100 flex items-center justify-between">
            <% unassigned = unassigned_transaction_count rescue 0 %>
            <% if unassigned > 0 %>
              <%= link_to unassigned_transactions_path, class: "flex items-center gap-1 text-sm text-amber-700 bg-amber-100 px-3 py-1 rounded-full" do %>
                <span class="font-semibold"><%= unassigned %></span> unassigned
              <% end %>
            <% else %>
              <span></span>
            <% end %>
            <%= link_to "Sign out", destroy_user_session_path, data: { turbo_method: :delete }, class: "text-sm text-gray-500" %>
          </div>
        </div>
      </nav>
    <% end %>

    <% if notice.present? %>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4" id="flash-notice">
        <div class="bg-green-50 border border-green-200 text-green-800 rounded-lg px-4 py-3 text-sm">
          <%= notice %>
        </div>
      </div>
    <% end %>
    <% if alert.present? %>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4" id="flash-alert">
        <div class="bg-red-50 border border-red-200 text-red-800 rounded-lg px-4 py-3 text-sm">
          <%= alert %>
        </div>
      </div>
    <% end %>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <%= yield %>
    </main>

    <turbo-frame id="modal"></turbo-frame>
  </body>
</html>
