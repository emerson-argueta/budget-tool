<%= content_for :title, "Dashboard" %>

<div class="mb-6 flex flex-wrap items-center justify-between gap-3">
  <h1 class="text-2xl font-bold text-gray-900"><%= @month_label %></h1>
  <div class="flex gap-2">
    <% if current_user.plaid_items.any? %>
      <%= button_to "Sync Banks", plaid_sync_path, method: :post, class: "btn-secondary text-sm" %>
    <% end %>
    <% if @unassigned_count > 0 %>
      <%= link_to "#{@unassigned_count} to assign →", unassigned_transactions_path,
          class: "btn-primary text-sm" %>
    <% end %>
  </div>
</div>

<% if @budget.nil? %>
  <div class="bg-white rounded-xl border border-gray-200 p-8 text-center">
    <p class="text-gray-500 mb-4">No budget set up for this month yet.</p>
    <%= link_to "Create Budget", budgets_path, class: "btn-primary" %>
  </div>
<% else %>

  <!-- Monthly Snapshot -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <%= link_to income_transactions_budget_path(@budget),
          class: "group block",
          data: { turbo_frame: "modal" } do %>
        <p class="text-xs font-medium text-gray-500 group-hover:text-gray-700 uppercase tracking-wide mb-1">Income ↗</p>
        <p class="text-2xl font-bold text-gray-900"><%= money(@total_income) %></p>
      <% end %>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Spent</p>
      <p class="text-2xl font-bold text-gray-900"><%= money(@total_spent) %></p>
    </div>
    <div class="bg-white rounded-xl border border-gray-200 p-5">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wide mb-1">Remaining</p>
      <p class="text-2xl font-bold <%= @remaining.negative? ? 'text-red-600' : 'text-green-600' %>">
        <%= money(@remaining) %>
      </p>
    </div>
    <% to_assign = @to_assign %>
    <div class="bg-white rounded-xl border <%= to_assign.zero? ? 'border-green-300' : 'border-amber-300' %> p-5">
      <p class="text-xs font-medium <%= to_assign.zero? ? 'text-green-600' : 'text-amber-600' %> uppercase tracking-wide mb-1">To Assign</p>
      <p class="text-2xl font-bold <%= to_assign.zero? ? 'text-green-700' : 'text-amber-700' %>">
        <%= money(to_assign) %> <%= "✓" if to_assign.zero? %>
      </p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

    <!-- Category Progress -->
    <div class="lg:col-span-2">
      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 flex items-center justify-between">
          <h2 class="font-semibold text-gray-900">Budget Categories</h2>
          <%= link_to "Full Budget →", budget_path(Date.today.strftime("%Y-%m")), class: "text-sm text-indigo-600 hover:underline" %>
        </div>
        <% if @categories.empty? %>
          <p class="px-6 py-8 text-center text-gray-400 text-sm">No categories yet. <%= link_to "Set up your budget →", budget_path(Date.today.strftime("%Y-%m")), class: "text-indigo-600 hover:underline" %></p>
        <% else %>
          <div class="divide-y divide-gray-100">
            <% @categories.each do |cat| %>
              <div class="px-6 py-3 flex items-center gap-3">
                <% if cat.emoji.present? %>
                  <span class="text-base w-6 text-center"><%= cat.emoji %></span>
                <% end %>
                <div class="flex-1 min-w-0">
                  <div class="flex items-center justify-between mb-1">
                    <span class="text-sm font-medium text-gray-900 truncate"><%= cat.name %></span>
                    <span class="text-sm <%= cat.over_budget? ? 'text-red-600 font-semibold' : 'text-gray-500' %> ml-2 whitespace-nowrap">
                      <%= money(cat.spent) %> / <%= money(cat.planned_amount) %>
                    </span>
                  </div>
                  <div class="h-2 bg-gray-100 rounded-full overflow-hidden">
                    <div class="h-full rounded-full <%= cat.over_budget? ? 'bg-red-500' : cat.percent_spent > 80 ? 'bg-amber-400' : 'bg-indigo-500' %>"
                         style="width: <%= cat.percent_spent %>%"></div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>

      <% if @over_budget_categories.any? %>
        <div class="mt-4 bg-red-50 border border-red-200 rounded-xl p-4">
          <p class="text-sm font-semibold text-red-700 mb-2">⚠ Over budget:</p>
          <div class="flex flex-wrap gap-2">
            <% @over_budget_categories.each do |cat| %>
              <span class="text-xs bg-red-100 text-red-700 px-2 py-1 rounded-full">
                <%= cat.emoji %> <%= cat.name %> (<%= money(cat.remaining.abs) %> over)
              </span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <!-- Right column: Recent Transactions + Accounts + Sinking Funds -->
    <div class="space-y-6">

      <!-- Recent Transactions -->
      <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
        <div class="px-4 py-3 border-b border-gray-100 flex items-center justify-between">
          <h2 class="font-semibold text-gray-900 text-sm">Recent Transactions</h2>
          <%= link_to "All →", transactions_path, class: "text-xs text-indigo-600 hover:underline" %>
        </div>
        <div class="divide-y divide-gray-100">
          <% if @recent_transactions.empty? %>
            <p class="px-4 py-6 text-center text-xs text-gray-400">No transactions yet.</p>
          <% else %>
            <% @recent_transactions.each do |txn| %>
              <div class="px-4 py-2.5 flex items-center justify-between gap-2">
                <div class="min-w-0">
                  <p class="text-xs font-medium text-gray-900 truncate"><%= txn.display_name %></p>
                  <p class="text-xs text-gray-400"><%= txn.date.strftime("%b %-d") %> · <%= txn.budget_category&.name || "Unassigned" %></p>
                </div>
                <% display_amount = -txn.amount %>
                <span class="text-xs font-medium whitespace-nowrap <%= display_amount.positive? ? 'text-green-600' : 'text-red-600' %>">
                  <%= display_amount.positive? ? "+#{money(display_amount)}" : money(display_amount) %>
                </span>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>

      <!-- Account Balances -->
      <% if @accounts.any? %>
        <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
          <div class="px-4 py-3 border-b border-gray-100">
            <h2 class="font-semibold text-gray-900 text-sm">Accounts</h2>
          </div>
          <div class="divide-y divide-gray-100">
            <% @accounts.each do |account| %>
              <div class="px-4 py-2.5 flex items-center justify-between">
                <div>
                  <p class="text-xs font-medium text-gray-900"><%= account.display_name %></p>
                  <p class="text-xs text-gray-400"><%= account.institution_name %></p>
                </div>
                <span class="text-xs font-semibold text-gray-900"><%= money(account.current_balance || 0) %></span>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Sinking Funds Preview -->
      <% if @sinking_funds.any? %>
        <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
          <div class="px-4 py-3 border-b border-gray-100 flex items-center justify-between">
            <h2 class="font-semibold text-gray-900 text-sm">Sinking Funds</h2>
            <%= link_to "All →", sinking_funds_path, class: "text-xs text-indigo-600 hover:underline" %>
          </div>
          <div class="divide-y divide-gray-100">
            <% @sinking_funds.first(4).each do |fund| %>
              <div class="px-4 py-2.5">
                <div class="flex items-center justify-between mb-1">
                  <span class="text-xs font-medium text-gray-900"><%= fund.emoji %> <%= fund.name %></span>
                  <span class="text-xs text-gray-500"><%= money(fund.current_amount) %> / <%= money(fund.goal_amount) %></span>
                </div>
                <div class="h-1.5 bg-gray-100 rounded-full overflow-hidden">
                  <div class="h-full rounded-full bg-indigo-400" style="width: <%= fund.percent_complete %>%"></div>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>

    </div>
  </div>
<% end %>

<!-- Plaid Connect CTA (if no banks) -->
<% if current_user.plaid_items.empty? %>
  <div class="mt-6 bg-indigo-50 border border-indigo-200 rounded-xl p-6 flex items-center justify-between">
    <div>
      <p class="font-medium text-indigo-900">Connect your bank to auto-import transactions</p>
      <p class="text-sm text-indigo-600 mt-1">Uses Plaid — supports 10,000+ US banks.</p>
    </div>
    <%= link_to "Connect a Bank", accounts_path, class: "btn-primary" %>
  </div>
<% end %>
