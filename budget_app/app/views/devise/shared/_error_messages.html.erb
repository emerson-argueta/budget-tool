<% if resource.errors.any? %>
  <div class="mb-4 bg-red-50 border border-red-200 rounded-lg px-4 py-3" data-turbo-temporary>
    <p class="text-sm font-medium text-red-700 mb-1">
      <%= pluralize(resource.errors.count, "error") %> prevented this from being saved:
    </p>
    <ul class="list-disc list-inside space-y-0.5">
      <% resource.errors.full_messages.each do |msg| %>
        <li class="text-sm text-red-600"><%= msg %></li>
      <% end %>
    </ul>
  </div>
<% end %>
