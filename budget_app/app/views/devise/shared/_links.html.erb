<div class="mt-6 space-y-2 text-center text-sm">
  <%- if controller_name != 'sessions' %>
    <p><%= link_to "Sign in to your account", new_session_path(resource_name), class: "text-indigo-600 hover:underline" %></p>
  <% end %>

  <%- if devise_mapping.registerable? && controller_name != 'registrations' %>
    <p><%= link_to "Create an account", new_registration_path(resource_name), class: "text-indigo-600 hover:underline" %></p>
  <% end %>

  <%- if devise_mapping.recoverable? && controller_name != 'passwords' && controller_name != 'registrations' %>
    <p><%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-gray-400 hover:text-gray-600 hover:underline" %></p>
  <% end %>

  <%- if devise_mapping.confirmable? && controller_name != 'confirmations' %>
    <p><%= link_to "Resend confirmation", new_confirmation_path(resource_name), class: "text-gray-400 hover:text-gray-600 hover:underline" %></p>
  <% end %>

  <%- if devise_mapping.lockable? && resource_class.unlock_strategy_enabled?(:email) && controller_name != 'unlocks' %>
    <p><%= link_to "Resend unlock instructions", new_unlock_path(resource_name), class: "text-gray-400 hover:text-gray-600 hover:underline" %></p>
  <% end %>
</div>
